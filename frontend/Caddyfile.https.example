# Template for a future server with a real domain.
# Copy this file over Caddyfile or mount it as /etc/caddy/Caddyfile
# only after DNS points the domain to the server.

example.com {
	root * /srv
	encode zstd gzip

	handle /_proxy_health {
		respond "ok" 200
	}

	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
